{
  "version": 2,
  "functions": {
    "api/**/*.js": {
      "runtime": "nodejs20.x"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    }
  ],
  "env": {
    "STEAM_API_KEY": "@steam_api_key",
    "FRONTEND_URL": "@frontend_url",
    "BACKEND_URL": "@backend_url"
  }
}